# ---- Public (safe to expose; used in the browser) ----
# Production site origin (no trailing slash). Used for canonical URLs / sitemap.
NEXT_PUBLIC_SITE_URL=https://abk-scientific.com

NEXT_PUBLIC_CONTACT_EMAIL=hello@yourdomain.com
# Profile URLs (defaults also set in src/content/site.ts)
NEXT_PUBLIC_LINKEDIN_URL=https://www.linkedin.com/in/aquib-belal-khan-33631914b
NEXT_PUBLIC_GITHUB_URL=https://github.com/insight2017aquib
NEXT_PUBLIC_SCHOLAR_URL=
# Cal.com/Calendly link. Leave empty to fall back to an email CTA.
NEXT_PUBLIC_CAL_URL=

# Chemistry Companion links (leave empty until you have them).
# Download should point at a GitHub Releases URL — do NOT host the installer in this repo.
NEXT_PUBLIC_CC_GITHUB_URL=
NEXT_PUBLIC_CC_DOWNLOAD_URL=

# ---- Server-only (never exposed to the browser) ----
# Contact form email delivery via Resend (https://resend.com). All three required to send.
RESEND_API_KEY=
CONTACT_INBOX=you@yourdomain.com
CONTACT_FROM=ABK Scientific <inquiries@yourdomain.com>
# Optional: Resend Audience ID for newsletter signups
RESEND_AUDIENCE_ID=
